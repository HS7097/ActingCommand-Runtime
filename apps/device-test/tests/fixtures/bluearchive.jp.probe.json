{
  "schema_version": "0.1",
  "id": "bluearchive.jp.task-center-probe",
  "steps": [
    {
      "id": "home_to_task",
      "page_id": "bluearchive/home",
      "action": {
        "type": "click",
        "target_id": "navigation/home_to_task",
        "effect": "navigation_only"
      },
      "expect_after": {
        "page_id": "navigation/home_to_task/arrive_anchor",
        "timeout_ms": 3000,
        "interval_ms": 100
      }
    },
    {
      "id": "return_home",
      "page_id": "navigation/home_to_task/arrive_anchor",
      "action": {
        "type": "click",
        "target_id": "control/home",
        "effect": "navigation_only"
      },
      "expect_after": {
        "page_id": "bluearchive/home",
        "timeout_ms": 3000,
        "interval_ms": 100
      }
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://actingcommand.local/contracts/scheduling/activity.schema.json",
  "title": "ActingCommand Scheduling Activity v1",
  "type": "object",
  "required": ["schema_version", "catalog", "profiles"],
  "properties": {
    "schema_version": { "const": "actingcommand.scheduling.v1" },
    "catalog": { "$ref": "./common.schema.json#/$defs/catalog" },
    "profiles": {
      "type": "array",
      "maxItems": 1024,
      "items": { "$ref": "#/$defs/profile" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "window": {
      "type": "object",
      "required": ["weekdays", "utc_offset_minutes", "start_minute_of_day", "end_minute_of_day"],
      "properties": {
        "weekdays": {
          "type": "array",
          "minItems": 1,
          "maxItems": 7,
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 1, "maximum": 7 }
        },
        "utc_offset_minutes": { "type": "integer", "minimum": -840, "maximum": 840 },
        "start_minute_of_day": { "type": "integer", "minimum": 0, "maximum": 1439 },
        "end_minute_of_day": { "type": "integer", "minimum": 0, "maximum": 1439 }
      },
      "additionalProperties": false
    },
    "goal": {
      "type": "object",
      "required": ["id", "metric", "target", "deadline_unix_ms", "strategic_weight_milli", "best_effort"],
      "properties": {
        "id": { "$ref": "./common.schema.json#/$defs/identifier" },
        "metric": { "$ref": "./common.schema.json#/$defs/metric" },
        "target": { "type": "integer" },
        "deadline_unix_ms": { "type": "integer", "minimum": 0 },
        "strategic_weight_milli": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "best_effort": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "detectionBudget": {
      "type": "object",
      "required": ["window_dispatch_limit", "window_runtime_ms", "expected_duration_ms"],
      "properties": {
        "window_dispatch_limit": { "type": "integer", "minimum": 1, "maximum": 1000000 },
        "window_runtime_ms": { "type": "integer", "minimum": 1 },
        "expected_duration_ms": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "profile": {
      "type": "object",
      "required": [
        "id",
        "scope",
        "windows",
        "daily_budget",
        "max_window_iterations",
        "session_max_ms",
        "detection_budget",
        "minimum_interval_ms",
        "maximum_interval_ms",
        "seed_source",
        "resample_policy",
        "importance_milli",
        "goals"
      ],
      "properties": {
        "id": { "$ref": "./common.schema.json#/$defs/identifier" },
        "scope": { "$ref": "./common.schema.json#/$defs/scope" },
        "windows": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": { "$ref": "#/$defs/window" }
        },
        "daily_budget": { "type": "integer", "minimum": 1, "maximum": 1000000 },
        "max_window_iterations": { "type": "integer", "minimum": 1, "maximum": 1000000 },
        "session_max_ms": { "type": "integer", "minimum": 1 },
        "detection_budget": { "$ref": "#/$defs/detectionBudget" },
        "minimum_interval_ms": { "type": "integer", "minimum": 0 },
        "maximum_interval_ms": { "type": "integer", "minimum": 0 },
        "seed_source": { "const": "ledger" },
        "resample_policy": { "const": "same_round_stable" },
        "importance_milli": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "goals": {
          "type": "array",
          "maxItems": 128,
          "items": { "$ref": "#/$defs/goal" }
        }
      },
      "additionalProperties": false
    }
  }
}

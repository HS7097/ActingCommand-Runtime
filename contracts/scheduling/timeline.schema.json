{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://actingcommand.local/contracts/scheduling/timeline.schema.json",
  "title": "ActingCommand Scheduling Timeline v1",
  "type": "object",
  "required": ["schema_version", "catalog", "events"],
  "properties": {
    "schema_version": { "const": "actingcommand.scheduling.v1" },
    "catalog": { "$ref": "./common.schema.json#/$defs/catalog" },
    "events": {
      "type": "array",
      "maxItems": 4096,
      "items": { "$ref": "#/$defs/event" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "event": {
      "type": "object",
      "required": ["id", "scope", "event_kind", "schedule", "duration_ms", "invalidates_fact_prefixes"],
      "properties": {
        "id": { "$ref": "./common.schema.json#/$defs/identifier" },
        "scope": { "$ref": "./common.schema.json#/$defs/scope" },
        "event_kind": { "enum": ["reset", "maintenance", "activity", "deadline"] },
        "schedule": { "$ref": "./common.schema.json#/$defs/clockSchedule" },
        "duration_ms": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "invalidates_fact_prefixes": {
          "type": "array",
          "maxItems": 128,
          "uniqueItems": true,
          "items": { "$ref": "./common.schema.json#/$defs/identifier" }
        }
      },
      "additionalProperties": false
    }
  }
}

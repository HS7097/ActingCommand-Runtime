{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://actingcommand.local/contracts/scheduling/pools.schema.json",
  "title": "ActingCommand Scheduling Pools v1",
  "type": "object",
  "required": ["schema_version", "catalog", "pools"],
  "properties": {
    "schema_version": { "const": "actingcommand.scheduling.v1" },
    "catalog": { "$ref": "./common.schema.json#/$defs/catalog" },
    "pools": {
      "type": "array",
      "maxItems": 1024,
      "items": { "$ref": "#/$defs/pool" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "observation": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "fact_key"],
          "properties": {
            "kind": { "const": "fact" },
            "fact_key": { "$ref": "./common.schema.json#/$defs/identifier" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "task_id", "outcome_key"],
          "properties": {
            "kind": { "const": "outcome" },
            "task_id": { "$ref": "./common.schema.json#/$defs/identifier" },
            "outcome_key": { "$ref": "./common.schema.json#/$defs/identifier" }
          },
          "additionalProperties": false
        }
      ]
    },
    "pool": {
      "type": "object",
      "required": ["id", "scope", "capacity", "projection", "observation", "group_delay"],
      "properties": {
        "id": { "$ref": "./common.schema.json#/$defs/identifier" },
        "scope": { "$ref": "./common.schema.json#/$defs/scope" },
        "capacity": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "projection": {
          "type": "object",
          "required": ["amount", "per_ms"],
          "properties": {
            "amount": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
            "per_ms": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 }
          },
          "additionalProperties": false
        },
        "observation": { "$ref": "#/$defs/observation" },
        "group_delay": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": ["minimum_delay_ms", "maximum_delay_ms"],
              "properties": {
                "minimum_delay_ms": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
                "maximum_delay_ms": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }
              },
              "additionalProperties": false
            }
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
